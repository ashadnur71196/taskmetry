  </defs>
  <rect x="30" y="30" width="120" height="120" rx="20" fill="url(#grad)"/>
  <text x="90" y="110" font-family="Arial, sans-serif" font-size="80" font-weight="bold" text-anchor="middle" fill="white">T</text>
</svg>
